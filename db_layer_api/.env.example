# postgres-meta API URL (internal — admin_ui only)
PG_META_URL=http://postgres-meta:8080

# --- postgres-meta server ---
PG_META_HOST=0.0.0.0
PG_META_PORT=8080

# Default Postgres (fallback; admin_ui sends per-request `pg` header for each project)
# Hostname only — NOT https://... and NOT a full postgres:// URL (use PG_META_DB_URL for that)
PG_META_DB_HOST=postgres
PG_META_DB_PORT=5432
PG_META_DB_NAME=postgres
PG_META_DB_USER=postgres
PG_META_DB_PASSWORD=replace-me
PG_META_DB_SSL_MODE=require

# Managed Postgres example (Coolify / cloud):
# PG_META_DB_URL=postgresql://user:pass@zsi6j1g15rgxyjgmmmv7uecp.intoship.cloud:5432/postgres
# PG_META_DB_SSL_MODE=require

# Or single connection string (overrides individual vars above)
# PG_META_DB_URL=postgresql://user:pass@postgres:5432/postgres

# Optional tuning
# PG_CONN_TIMEOUT_SECS=15
# PG_QUERY_TIMEOUT_SECS=55
# PG_META_MAX_RESULT_SIZE_MB=20
# PG_META_MAX_BODY_LIMIT_MB=3

# Optional TLS to Postgres
# PG_META_DB_SSL_ROOT_CERT=/path/to/ca.pem
