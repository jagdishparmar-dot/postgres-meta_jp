# Copy to .env at repo root, then edit secrets before `docker compose up`.
# Docker Compose reads .env for variable substitution; admin_ui also loads it at runtime.
# Internal service URLs (Postgres, Redis, RustFS, postgres-meta) are wired by docker-compose.yml.

# --- Published port ---
ADMIN_UI_PORT=3000

# --- PostgreSQL (supabase/postgres — pg_cron, pg_net, PostGIS, etc.) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-stack-password
# https://hub.docker.com/r/supabase/postgres/tags — must match existing volume major version
POSTGRES_IMAGE=supabase/postgres:17.6.1.136

# --- Redis (shared instance; projects use logical DB 0–15) ---
REDIS_PASSWORD=redislocal

# --- RustFS / S3-compatible storage (required for Storage UI) ---
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_REGION=us-east-1
RUSTFS_FORCE_PATH_STYLE=true

# --- Admin login (required in production / Docker) ---
ADMIN_ID=admin
ADMIN_PASSWORD=ChangeMe-Admin-Stack-Password-2026!
ADMIN_SESSION_SECRET=ChangeMe-Admin-Session-Secret-Stack-32chars-min
CONNECTION_VAULT_KEY=vault-stack-key-16

# --- App URL / cookies (local HTTP stack) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
COOKIE_SECURE=false
ENABLE_HSTS=false

# --- Optional: behind TLS reverse proxy ---
# NEXT_PUBLIC_APP_URL=https://admin.example.com
# COOKIE_SECURE=true
# ENABLE_HSTS=true
