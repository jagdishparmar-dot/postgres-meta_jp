# postgres-meta API
PG_META_URL=http://localhost:1337

# --- Master Postgres instance (list / create / open project databases) ---
# Credentials from this URL are reused for every project database on the same host.
PG_MASTER_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Platform control plane (project metadata only) ---
# Separate database on the same (or another) Postgres server.
# Created by: npm run platform:setup
PLATFORM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pgadmin_platform

# Optional: override URL used only to CREATE the platform database
# PLATFORM_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Optional: passphrase for legacy AES connection vault (min 16 chars).
# If unset, a key is auto-generated in `.data/vault.key`.
# CONNECTION_VAULT_KEY=change-me-to-a-long-secret

# Optional: public app URL for absolute project API URLs in settings
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Storage (RustFS / S3-compatible) ---
# One physical bucket per project; logical buckets + object metadata live in the project DB.
# Local: docker compose -f docker-compose.rustfs.yml up -d
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_REGION=us-east-1
RUSTFS_FORCE_PATH_STYLE=true
# Optional public base URL for objects (defaults to endpoint)
# RUSTFS_PUBLIC_URL=http://localhost:9000

# Optional content-scan webhook (POST JSON; { "ok": true|false })
# STORAGE_SCAN_WEBHOOK_URL=https://scanner.example/hook
